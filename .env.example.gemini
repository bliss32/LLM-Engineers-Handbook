# --- Required settings even when working locally. ---

# Gemini / OpenAI API Config (已切換為 Gemini 替代方案)
GEMINI_API_KEY=你的AIzaSy開頭金鑰請貼在這裡
OPENAI_MODEL_ID=gemini-1.5-pro

# 保留 OPENAI_API_KEY 欄位防呆，直接填入一樣的 Gemini 金鑰來欺騙底層檢查
OPENAI_API_KEY=你的AIzaSy開頭金鑰請貼在這裡

# Huggingface API Config
HUGGINGFACE_ACCESS_TOKEN=你的hf_開頭金鑰請貼在這裡

# Comet ML (during training and inference) 
COMET_API_KEY=你的Comet金鑰請貼在這裡

# --- Required settings when deploying the code. ---
# --- Otherwise, default values work fine. ---

# MongoDB database
DATABASE_HOST="mongodb://llm_engineering:llm_engineering@127.0.0.1:27017"

# Qdrant vector database
USE_QDRANT_CLOUD=false
QDRANT_CLOUD_URL=str
QDRANT_APIKEY=str

# AWS Authentication
AWS_ARN_ROLE=str
AWS_REGION=eu-central-1
AWS_ACCESS_KEY=str
AWS_SECRET_KEY=str
